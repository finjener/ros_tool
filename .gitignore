# ROS Tool Project .gitignore
# =========================

# OS-specific files
# -----------------
.DS_Store
Thumbs.db
.directory
*~
*.swp
.*.swp
*.kate-swp
.ros_tool.sh.kate-swp

# Build artifacts and outputs
# ---------------------------
# Kernel files
kernel-files/
rockpro-files/linux-radxa-stable-3.0
rockpro-files/linux-rockchip
rockpro-files/initrd.img
rockpro-files/linaro*

# Toolchains
gcc-linaro-*
arm-eabi-4.6/

# Rockchip specific
rockchip-tools/Linux/boot-linux.img
rockchip-tools/Linux/rootfs.img
rockchip-tools/log
rockchip-tools/update.img
rockchip-tools/update_tmp.img
rockchip-tools/rockchip-mkbootimg

# Filesystems and images
rootfs-*.img
*.ext4
*.img
*.iso

# Build directories and temporary files
# -------------------------------------
sys/
build/
output/
temp/
tmp/
downloads/
dl/
config_copied
last_config_backup

# Logs and debugging
# -----------------
*.log
scripts/build.log
*.dump
core.*

# Backup files
# -----------
*.bak
*.old
*.orig
*.rej
*.BACKUP.*
*.BASE.*
*.LOCAL.*
*.REMOTE.*
*.recovery

# Configuration files that should be created locally
# -------------------------------------------------
local.conf
.config
.lastconfig

!.gitignore
!README.md
!LICENSE